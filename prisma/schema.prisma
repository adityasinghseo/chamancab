generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// ADMINS
// ─────────────────────────────────────────────
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN") // SUPER_ADMIN, ADMIN etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// CITIES
// ─────────────────────────────────────────────
model City {
  id            String   @id @default(cuid())
  name          String
  state         String
  isOperational Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  locations         Location[]
  routePricingsFrom RoutePricing[] @relation("RoutePricingFrom")
  routePricingsTo   RoutePricing[] @relation("RoutePricingTo")
  rentalPricings    RentalPricing[]
  bookingsFrom      Booking[]      @relation("BookingFromCity")
  bookingsTo        Booking[]      @relation("BookingToCity")
  distancesFrom     CityDistance[] @relation("DistanceFromCity")
  distancesTo       CityDistance[] @relation("DistanceToCity")
}

// ─────────────────────────────────────────────
// CITY DISTANCES (Dynamic One-Way Mapping)
// ─────────────────────────────────────────────
model CityDistance {
  id         String   @id @default(cuid())
  fromCityId String
  toCityId   String
  distanceKm Float

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fromCity   City     @relation("DistanceFromCity", fields: [fromCityId], references: [id], onDelete: Cascade)
  toCity     City     @relation("DistanceToCity",   fields: [toCityId],   references: [id], onDelete: Cascade)

  @@unique([fromCityId, toCityId])
}

// ─────────────────────────────────────────────
// LOCATIONS / PICKUP HUBS
// ─────────────────────────────────────────────
model Location {
  id            String   @id @default(cuid())
  cityId        String
  landmark      String
  latitude      Float?
  longitude     Float?
  isOperational Boolean  @default(true)
  createdAt     DateTime @default(now())

  city           City      @relation(fields: [cityId], references: [id])
  pickupBookings Booking[] @relation("BookingPickupLocation")
  dropBookings   Booking[] @relation("BookingDropLocation")
}

// ─────────────────────────────────────────────
// CARS
// ─────────────────────────────────────────────
model Car {
  id              String   @id @default(cuid())
  name            String   // e.g. "Wagon R CNG"
  type            String   // "Hatchback" | "Sedan" | "SUV" | "MUV"
  fuelType        String   // "CNG" | "Petrol" | "Diesel"
  seats           Int
  hasAC           Boolean  @default(true)
  luggageCapacity Int      @default(2) // number of bags
  imageUrl        String?
  description     String?
  isActive        Boolean  @default(true)
  totalUnits      Int      @default(1)

  isOneWayAvailable      Boolean  @default(true)
  isLocalRentalAvailable Boolean  @default(true)
  isRoundTripAvailable   Boolean  @default(true)

  // Dynamic Pricing Fields
  perKmRateOneWay       Float    @default(0)
  perKmRateRoundTrip    Float    @default(0)
  shortTripThreshold    Int      @default(30)
  shortTripMinFare      Float    @default(500)
  isShortTripRoundLogic Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  routePricings  RoutePricing[]
  rentalPricings RentalPricing[]
  bookings       Booking[]
  pricingSlabs   PricingSlab[]
}

// ─────────────────────────────────────────────
// PRICING SLAB — fixed fare buckets for short trips
// ─────────────────────────────────────────────
model PricingSlab {
  id        String   @id @default(cuid())
  carId     String
  minKm     Int
  maxKm     Int
  fixedFare Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// RENTAL PACKAGES (4hr/40km etc.)
// ─────────────────────────────────────────────
model RentalPackage {
  id          String   @id @default(cuid())
  name        String   // "4hr/40km"
  hours       Int
  kilometers  Int
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0) // for display ordering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pricings RentalPricing[]
  bookings Booking[]
}

// ─────────────────────────────────────────────
// ROUTE PRICING — price per (fromCity → toCity) per Car per TripType
// Admin sets: Delhi→Jaipur, WagonR, ONE_WAY = ₹2800
// ─────────────────────────────────────────────
model RoutePricing {
  id          String   @id @default(cuid())
  fromCityId  String
  toCityId    String
  carId       String
  tripType    String   // "ONE_WAY" | "ROUND_TRIP"
  price       Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fromCity City @relation("RoutePricingFrom", fields: [fromCityId], references: [id])
  toCity   City @relation("RoutePricingTo",   fields: [toCityId],   references: [id])
  car      Car  @relation(fields: [carId], references: [id])

  @@unique([fromCityId, toCityId, carId, tripType])
}

// ─────────────────────────────────────────────
// RENTAL PRICING — price per Package per Car per City
// Admin sets: Delhi, 4hr/40km, WagonR = ₹1200
// ─────────────────────────────────────────────
model RentalPricing {
  id        String   @id @default(cuid())
  cityId    String
  packageId String
  carId     String
  price     Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city    City          @relation(fields: [cityId],    references: [id])
  package RentalPackage @relation(fields: [packageId], references: [id])
  car     Car           @relation(fields: [carId],     references: [id])

  @@unique([cityId, packageId, carId])
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────
model Booking {
  id        String @id @default(cuid())
  referenceId String @unique // e.g. "CH-2024-001"

  // Trip type
  tripType  String // "ONE_WAY" | "ROUND_TRIP" | "RENTAL"

  // Customer info (no login required)
  customerName  String
  customerPhone String
  customerEmail String?

  fromCityId        String?
  toCityId          String?
  pickupLocationId  String?
  dropLocationId    String?
  pickupAddress     String?
  dropAddress       String?
  packageId         String? // for RENTAL trips
  carId             String

  pickupDate DateTime
  pickupTime String

  // Pricing
  amount     Float   // Legacy usage depending on structure
  totalFare  Float   @default(0)
  paidAmount Float   @default(0)

  // Statuses
  status        String @default("PENDING")   // PENDING | CONFIRMED | COMPLETED | CANCELLED
  paymentStatus String @default("PENDING")   // PENDING | PARTIAL_PAID | PAID_FULL | PAID_OFFLINE | FAILED
  paymentMethod String @default("PAY_ON_PICKUP") // PAY_ON_PICKUP | RAZORPAY

  // User Info (optional if they log in)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  // Admin notes
  specialRequests String?
  adminNotes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromCity       City?          @relation("BookingFromCity",        fields: [fromCityId],       references: [id])
  toCity         City?          @relation("BookingToCity",          fields: [toCityId],         references: [id])
  pickupLocation Location?      @relation("BookingPickupLocation",  fields: [pickupLocationId], references: [id])
  dropLocation   Location?      @relation("BookingDropLocation",    fields: [dropLocationId],   references: [id])
  package        RentalPackage? @relation(fields: [packageId],      references: [id])
  car            Car            @relation(fields: [carId],          references: [id])
  payment        Payment?
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────
model Payment {
  id                String   @id @default(cuid())
  bookingId         String   @unique
  method            String   // "PAY_ON_PICKUP" | "RAZORPAY"
  amount            Float
  status            String   // "PENDING" | "SUCCESS" | "FAILED"
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

// ─────────────────────────────────────────────
// USERS & AUTHENTICATION
// ─────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  selfDriveBookings SelfDriveBooking[]
  driverBookings    DriverBooking[]
}

model Otp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

// ─────────────────────────────────────────────
// SELF DRIVE CARS & BOOKINGS
// ─────────────────────────────────────────────
model SelfDriveCar {
  id              String   @id @default(cuid())
  name            String
  type            String   // "Hatchback", "Sedan", etc.
  fuelType        String
  transmission    String   @default("Manual")
  seats           Int
  price12hr       Float
  price24hr       Float
  extraKmRate     Float
  extraHourRate   Float
  under12HourRate Float    @default(150)
  deposit         Float    @default(5000)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        SelfDriveBooking[]
}

model SelfDriveBooking {
  id              String   @id @default(cuid())
  referenceId     String   @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  
  carId           String
  car             SelfDriveCar @relation(fields: [carId], references: [id])

  pickupLocation  String
  pickupDate      DateTime // Represents the date
  pickupTime      String   // Represents "14:30"
  returnDate      DateTime
  returnTime      String

  amount          Float    // Estimated rent sum
  deposit         Float    @default(5000)
  
  status          String   @default("PENDING") // PENDING | CONFIRMED | COMPLETED | CANCELLED
  paymentStatus   String   @default("PENDING")
  paymentMethod   String   @default("RAZORPAY")
  razorpayPaymentId String?

  userId          String?
  user            User?    @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────
// DRIVERS & DRIVER BOOKINGS
// ─────────────────────────────────────────────
model Driver {
  id           String   @id @default(cuid())
  name         String
  dutyHours    String   // e.g., "8 Hours", "12 Hours"
  costPerHour  Float    
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  bookings     DriverBooking[]
}

model DriverBooking {
  id              String   @id @default(cuid())
  referenceId     String   @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id])

  pickupLocation  String
  startDate       DateTime
  startTime       String

  totalHours      Float    // e.g. 8, 12 based on the selection
  amount          Float

  status          String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  paymentStatus   String   @default("PENDING")
  paymentMethod   String   @default("RAZORPAY")
  razorpayPaymentId String?

  userId          String?
  user            User?    @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────
// OFFERS (Return Trip / Special Deals)
// ─────────────────────────────────────────────
model Offer {
  id            String   @id @default(cuid())
  fromCity      String
  toCity        String
  date          String   // display date e.g. "5 April 2026"
  time          String   // departure time e.g. "3:30 PM"
  price         Int      // discounted offer price
  originalPrice Int      // original price (for strikethrough)
  seatsAvailable Int     @default(1)
  validUntil    DateTime // auto-expire after this
  isActive      Boolean  @default(true)
  description   String?  // e.g. "Return trip - limited seats"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bookings      OfferBooking[]
}

model OfferBooking {
  id            String   @id @default(cuid())
  offer         Offer    @relation(fields: [offerId], references: [id])
  offerId       String
  customerName  String
  customerPhone String
  customerEmail String?
  seatsBooked   Int      @default(1)
  status        String   @default("PENDING")
  paymentStatus String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
